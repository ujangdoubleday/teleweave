# Token from BotFather (https://t.me/BotFather)
# Format: 123456789:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# A custom secret token you create to secure your Webhook
# Used to validate that incoming requests are actually from Telegram
# This must match the secret_token used when calling setWebhook
TELEGRAM_SECRET_TOKEN=your_random_secret_token_here

# Comma-separated list of allowed chat IDs (no spaces)
# Only updates from these Chat IDs will be processed (Early Exit feature)
# Example: 111111111,222222222
ALLOWED_CHAT_IDS=your_chat_id_here

# ─── Redis ───────────────────────────────────────────────────

# Redis Host for BullMQ (Use 127.0.0.1 for local, or Cloud provider IP/URL)
REDIS_HOST=127.0.0.1

# Redis Port (Default: 6379)
REDIS_PORT=6379
